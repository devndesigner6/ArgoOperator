# Database connection string (e.g. Neon Postgres pooled connection)
DATABASE_URL=postgres://...neon.tech/neondb?sslmode=require

# Blockfrost Preprod Project ID (for Cardano blockchain network connection)
BLOCKFROST_PROJECT_ID=preprod...

# Cerebras API Key (for fast Llama 3.3 70B inference)
CEREBRAS_API_KEY=...
# Optional: Cerebras Model override
CEREBRAS_MODEL=llama3.3-70b

# Steel API Key (for headless browser session execution)
STEEL_API_KEY=...

# A 32+ character random string to derive the Ed25519 PoE key pair
ARGO_POE_SEED=some_super_secret_seed_phrase_here

# Masumi Registry Service settings (optional)
MASUMI_REGISTRY_URL=https://your-masumi-host/api/v1
MASUMI_REGISTRY_API_KEY=...
